#include <stdio.h>
#include <stdlib.h>
#include <math.h>

typedef struct Node {
    int val;
    struct Node* left;
    struct Node* right;
} Node;

Node* newNode(int val) {
    Node* n = (Node*)malloc(sizeof(Node));
    n->val = val;
    n->left = n->right = NULL;
    return n;
}

int height(Node* root) {
    if (!root) return 0;

    int l = height(root->left);
    if (l == -1) return -1;

    int r = height(root->right);
    if (r == -1) return -1;

    if (abs(l - r) > 1) return -1;

    return (l > r ? l : r) + 1;
}

int isBalanced(Node* root) {
    return height(root) != -1;
}

int main() {
    Node* root = newNode(1);
    root->left = newNode(2);
    root->right = newNode(3);

    if (isBalanced(root))
        printf("Echilibrat\n");
    else
        printf("Nu este echilibrat\n");

    return 0;
}

